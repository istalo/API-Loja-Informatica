generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Produto {
  id          Int           @id @default(autoincrement())
  nome        String        @db.VarChar(60)
  estoque     Int           @db.SmallInt
  preco       Decimal       @db.Decimal(9,2)
  categoria   String        @db.VarChar(40)
  descricao   String?
  itensVenda  ItensVenda[]
  @@map ("produtos")
}

model Venda {
  id          Int           @id @default(autoincrement())
  cliente     Cliente       @relation(fields: [clienteId], references: [id])
  clienteId   Int
  formaPag    TipoPag
  total       Decimal       @db.Decimal(9,2)
  data        DateTime      @default(now())
  itensVenda  ItensVenda[]
  @@map ("vendas")
}

model Cliente {
  id          Int           @id @default(autoincrement())
  nome        String        @db.VarChar(40)
  email       String        @unique
  telefone    String?
  endereco    String        @db.VarChar(100)
  vendas      Venda[]
  @@map ("clientes")
}

model ItensVenda {
  id          Int           @id @default(autoincrement())
  venda       Venda        @relation(fields: [vendaId], references: [id])
  vendaId     Int
  produto     Produto       @relation(fields: [produtoId], references: [id])
  produtoId   Int
  quantidade  Int           @db.SmallInt
  precoUnid   Decimal       @db.Decimal(9,2)
  @@map ("itens_vendas")
}

enum TipoPag {
  Pix
  Boleto
  Debito
  Credito
}